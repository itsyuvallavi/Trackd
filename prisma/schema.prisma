generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobSource {
  MANUAL
  LINKEDIN
  INDEED
  COMPANY_SITE
  REFERRAL
  RECRUITER
  EU_REMOTE_JOBS
  WORKABLE
  ZIPRECRUITER
  LANDING_JOBS
  OTHER
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  ARCHIVED
}

enum JobPriority {
  A
  B
  C
}

enum ActivityType {
  NOTE
  STATUS_CHANGE
  EMAIL_UPDATE
  INTERVIEW
  REJECTION
  OFFER
}

enum NotificationType {
  AMBIGUOUS_MATCH
  NEW_JOB_DETECTED
  JOB_UPDATED
  SYNC_COMPLETE
  SYNC_ERROR
}

model Profile {
  id        String   @id           // Matches Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id          String      @id @default(cuid())
  userId      String

  // Core fields
  title       String
  company     String
  location    String?
  source      JobSource   @default(MANUAL)
  url         String?

  // Status tracking
  status      JobStatus   @default(SAVED)
  priority    JobPriority @default(B)

  // Dates
  savedAt     DateTime    @default(now())
  appliedAt   DateTime?
  interviewAt DateTime?
  nextAction  String?

  // Additional info
  tags        String[]    @default([])
  notes       String?
  salary      String?
  contactName String?
  contactEmail String?

  // Relations
  activities  Activity[]
  interviewSessions InterviewSession[]

  // Optional: link to Profile when we start using it
  // (no foreign key yet to avoid breaking existing data)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, status])
  @@index([userId, savedAt])
}

model Activity {
  id          String       @id @default(cuid())
  jobId       String
  userId      String

  type        ActivityType
  fromStatus  JobStatus?
  toStatus    JobStatus?
  description String?
  metadata    Json?        // Store AI-extracted context (interview dates, next steps, etc.)

  createdAt   DateTime     @default(now())

  // Relations
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt]) // For filtering by type and date (used in /today page)
}

enum EmailProvider {
  IMAP
  GMAIL_OAUTH
  MICROSOFT_OAUTH
}

model EmailIntegration {
  id          String        @id @default(cuid())
  userId      String        @unique

  provider    EmailProvider @default(IMAP)
  email       String

  // IMAP credentials (encrypted)
  imapHost    String?
  imapPort    Int?
  imapUsername String?
  imapPassword String?

  // OAuth tokens (for future Gmail/Microsoft integration)
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?

  // Sync status
  isActive     Boolean      @default(true)
  lastSyncedAt DateTime?
  lastError    String?

  // Auto-sync settings
  autoSyncEnabled  Boolean   @default(false)
  autoSyncFrequency Int      @default(60) // minutes
  nextSyncAt       DateTime?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
  @@index([userId, isActive]) // For filtering by active status
}

model ExtensionKey {
  id          String    @id @default(cuid())
  userId      String    @unique  // One active key per user (matches Profile.id / Supabase auth.users.id)
  keyHash     String    @unique  // SHA-256 hash for lookup (never store plain key)
  keyPrefix   String    // "tk_a1b2c3" - visible in UI for identification
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@index([keyHash])
  @@index([userId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  metadata    Json?            // Store additional data (jobId, emailId, matchedJobs, etc.)
  isRead      Boolean          @default(false)
  actionUrl   String?          // Optional link to relevant page
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model EmailSyncLog {
  id          String   @id @default(cuid())
  userId      String
  
  // Sync metadata
  startedAt   DateTime @default(now())
  completedAt DateTime?
  duration    Int?     // milliseconds
  
  // Sync source (manual, auto, cron)
  source      String   @default("manual") // "manual", "auto", "cron"
  
  // Sync statistics
  totalEmails        Int      @default(0)
  processedEmails    Int      @default(0)
  skippedEmails      Int      @default(0)
  skippedOther       Int      @default(0)
  skippedLowConfidence Int    @default(0)
  
  // Match results
  exactMatches       Int      @default(0)
  fuzzyMatches       Int      @default(0)
  ambiguousMatches   Int      @default(0)
  newJobsDetected    Int      @default(0)
  noMatches          Int      @default(0)
  
  // Actions taken
  jobsUpdated        Int      @default(0)
  notificationsCreated Int    @default(0)
  
  // Error handling
  success            Boolean  @default(true)
  errorMessage       String?
  
  // Additional details stored as JSON
  details            Json?    // Store detailed breakdown, email subjects, etc.
  
  createdAt   DateTime @default(now())
  
  @@index([userId, createdAt])
  @@index([userId, success])
}

enum InterviewType {
  TECHNICAL
  GENERAL
  MIXED
}

enum InterviewSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model InterviewSession {
  id          String   @id @default(cuid())
  userId      String
  jobId       String?  // Optional: link to specific job
  
  type        InterviewType @default(MIXED)
  status      InterviewSessionStatus @default(IN_PROGRESS)
  
  // Session metadata
  startedAt   DateTime @default(now())
  completedAt  DateTime?
  duration    Int?     // Duration in seconds
  
  // AI-generated content
  summary     String?  // Post-session summary
  strengths   String[] @default([]) // Identified strengths
  improvements String[] @default([]) // Areas for improvement
  tips        String[] @default([]) // Personalized tips
  
  // Relations
  messages    InterviewMessage[]
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([jobId])
}

model InterviewMessage {
  id          String   @id @default(cuid())
  sessionId   String
  
  role        String   // "user" | "assistant" | "system"
  content     String   // Message text
  audioUrl    String?  // Optional: store audio file URL if needed
  
  // Timing metadata
  timestamp   DateTime @default(now())
  duration    Int?     // For user messages: speaking duration in ms
  
  // AI analysis (for assistant messages)
  questionType String? // "technical" | "behavioral" | "general"
  feedback    Json?    // Real-time feedback metadata
  
  // Relations
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId, timestamp])
}

model ResumeSession {
  id                String   @id @default(cuid())
  userId            String
  
  // File storage (Supabase Storage)
  resumeFileUrl     String   // Supabase Storage URL
  resumeFileName    String   // Original filename
  resumeFileType    String   // "application/pdf", "text/plain", etc.
  
  // Optional: Keep for backwards compatibility or quick access
  resumeText        String?  // Optional: extracted text if needed
  
  improvedResumeText String?  // AI-improved version
  parsedResumeData   Json?    // Cached parsed resume data (JSON) for fast PDF generation
  
  // OpenAI Assistants API state
  openaiFileId      String?  // OpenAI file ID after upload
  openaiAssistantId String?  // OpenAI assistant ID
  openaiThreadId    String?  // OpenAI thread ID for conversation
  
  // Relations
  messages          ResumeMessage[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([userId, createdAt])
}

model ResumeMessage {
  id          String   @id @default(cuid())
  sessionId   String
  
  role        String   // "user" | "assistant"
  content     String   // Message text
  
  timestamp   DateTime @default(now())
  
  // Relations
  session     ResumeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId, timestamp])
}

enum FeedbackType {
  ERROR
  BUG
  FEATURE_REQUEST
  OTHER
}

enum FeedbackSource {
  WEB
  EXTENSION
}

enum FeedbackStatus {
  NEW
  REVIEWED
  RESOLVED
}

model Feedback {
  id          String         @id @default(cuid())
  userId      String?        // Optional - for authenticated users
  userEmail   String?        // Optional - for extension users or anonymous
  type        FeedbackType
  source      FeedbackSource
  title       String
  description String
  url         String?        // Page/context where issue occurred
  userAgent   String?        // Browser info
  metadata    Json?          // Additional context
  status      FeedbackStatus @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([source])
}

model PerformanceMetric {
  id          String   @id @default(cuid())
  
  // Core Web Vitals
  lcp         Float?   // Largest Contentful Paint (ms)
  fcp         Float?   // First Contentful Paint (ms)
  fid         Float?   // First Input Delay (ms)
  cls         Float?   // Cumulative Layout Shift (score)
  ttfb        Float?   // Time to First Byte (ms)
  inp         Float?   // Interaction to Next Paint (ms)
  
  // Route/page information
  route       String?  // e.g., "/jobs", "/board"
  pathname    String?  // Full pathname
  search      String?  // Query parameters
  
  // User/environment info
  country     String?  // ISO country code
  region      String?  // Region/state
  city        String?  // City
  deviceType  String?  // "mobile", "desktop", "tablet"
  browser     String?  // Browser name
  os          String?  // Operating system
  
  // Network/connection
  connectionType String? // "4g", "wifi", "3g", etc.
  effectiveType  String? // Network quality
  
  // Additional metadata
  metadata    Json?    // Store full payload for future analysis
  userAgent   String?  // Full user agent string
  
  createdAt   DateTime @default(now())
  
  @@index([route, createdAt])
  @@index([deviceType, createdAt])
  @@index([country, createdAt])
  @@index([createdAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobSource {
  MANUAL
  LINKEDIN
  INDEED
  COMPANY_SITE
  REFERRAL
  RECRUITER
  EU_REMOTE_JOBS
  WORKABLE
  ZIPRECRUITER
  LANDING_JOBS
  OTHER
  BOT
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  ARCHIVED
}

enum JobPriority {
  A
  B
  C
}

enum ActivityType {
  NOTE
  STATUS_CHANGE
  EMAIL_UPDATE
  INTERVIEW
  REJECTION
  OFFER
}

enum NotificationType {
  AMBIGUOUS_MATCH
  NEW_JOB_DETECTED
  JOB_UPDATED
  SYNC_COMPLETE
  SYNC_ERROR
}

model Profile {
  id        String   @id           // Matches Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id          String      @id @default(cuid())
  userId      String

  // Core fields
  title       String
  company     String
  location    String?
  source      JobSource   @default(MANUAL)
  url         String?

  // Status tracking
  status      JobStatus   @default(SAVED)
  priority    JobPriority @default(B)

  // Dates
  savedAt     DateTime    @default(now())
  appliedAt   DateTime?
  interviewAt DateTime?
  nextAction  String?

  // Additional info
  tags        String[]    @default([])
  notes       String?
  salary      String?
  contactName String?
  contactEmail String?

  // Bot-generated content
  coverLetter  String?    // AI-generated cover letter for this job
  botScore     Int?       // AI match score (0-100)
  botReasoning String?    // AI reasoning for the score

  /** Which adapter slug produced this row (e.g. `jsearch`, `jobs_search_api`) — see job-source-display */
  importSource    String?
  /** When importSource is jobs_search_api, which board (indeed, glassdoor, …) */
  importJobBoard   String?

  // Relations
  activities  Activity[]
  interviewSessions InterviewSession[]

  // Optional: link to Profile when we start using it
  // (no foreign key yet to avoid breaking existing data)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, status])
  @@index([userId, savedAt])
  @@index([userId, interviewAt])
  @@index([userId, appliedAt])
}

/** Fingerprints of jobs the user deleted — bot search skips re-importing the same URL or company+title. */
model DismissedJobImport {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  createdAt   DateTime @default(now())

  @@unique([userId, fingerprint])
  @@index([userId])
}

model Activity {
  id          String       @id @default(cuid())
  jobId       String
  userId      String

  type        ActivityType
  fromStatus  JobStatus?
  toStatus    JobStatus?
  description String?
  metadata    Json?        // Store AI-extracted context (interview dates, next steps, etc.)

  createdAt   DateTime     @default(now())

  // Relations
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt]) // For filtering by type and date (used in /today page)
}

enum EmailProvider {
  IMAP
  GMAIL_OAUTH
  MICROSOFT_OAUTH
}

model EmailIntegration {
  id          String        @id @default(cuid())
  userId      String        @unique

  provider    EmailProvider @default(IMAP)
  email       String

  // IMAP credentials (encrypted)
  imapHost    String?
  imapPort    Int?
  imapUsername String?
  imapPassword String?

  // OAuth tokens (for future Gmail/Microsoft integration)
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?

  // Sync status
  isActive     Boolean      @default(true)
  lastSyncedAt DateTime?
  lastError    String?

  // Auto-sync settings
  autoSyncEnabled  Boolean   @default(false)
  autoSyncFrequency Int      @default(60) // minutes
  nextSyncAt       DateTime?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
  @@index([userId, isActive]) // For filtering by active status
}

model ExtensionKey {
  id          String    @id @default(cuid())
  userId      String    @unique  // One active key per user (matches Profile.id / Supabase auth.users.id)
  keyHash     String    @unique  // SHA-256 hash for lookup (never store plain key)
  keyPrefix   String    // "tk_a1b2c3" - visible in UI for identification
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@index([keyHash])
  @@index([userId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  metadata    Json?            // Store additional data (jobId, emailId, matchedJobs, etc.)
  isRead      Boolean          @default(false)
  actionUrl   String?          // Optional link to relevant page
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

model EmailSyncLog {
  id          String   @id @default(cuid())
  userId      String
  
  // Sync metadata
  startedAt   DateTime @default(now())
  completedAt DateTime?
  duration    Int?     // milliseconds
  
  // Sync source (manual, auto, cron)
  source      String   @default("manual") // "manual", "auto", "cron"
  
  // Sync statistics
  totalEmails        Int      @default(0)
  processedEmails    Int      @default(0)
  skippedEmails      Int      @default(0)
  skippedOther       Int      @default(0)
  skippedLowConfidence Int    @default(0)
  
  // Match results
  exactMatches       Int      @default(0)
  fuzzyMatches       Int      @default(0)
  ambiguousMatches   Int      @default(0)
  newJobsDetected    Int      @default(0)
  noMatches          Int      @default(0)
  
  // Actions taken
  jobsUpdated        Int      @default(0)
  notificationsCreated Int    @default(0)
  
  // Error handling
  success            Boolean  @default(true)
  errorMessage       String?
  
  // Additional details stored as JSON
  details            Json?    // Store detailed breakdown, email subjects, etc.
  
  createdAt   DateTime @default(now())
  
  @@index([userId, createdAt])
  @@index([userId, success])
}

enum InterviewType {
  TECHNICAL
  GENERAL
  MIXED
}

enum InterviewSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model InterviewSession {
  id          String   @id @default(cuid())
  userId      String
  jobId       String?  // Optional: link to specific job
  
  type        InterviewType @default(MIXED)
  status      InterviewSessionStatus @default(IN_PROGRESS)
  
  // Session metadata
  startedAt   DateTime @default(now())
  completedAt  DateTime?
  duration    Int?     // Duration in seconds
  
  // AI-generated content
  summary     String?  // Post-session summary
  strengths   String[] @default([]) // Identified strengths
  improvements String[] @default([]) // Areas for improvement
  tips        String[] @default([]) // Personalized tips
  
  // Relations
  messages    InterviewMessage[]
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([jobId])
}

model InterviewMessage {
  id          String   @id @default(cuid())
  sessionId   String
  
  role        String   // "user" | "assistant" | "system"
  content     String   // Message text
  audioUrl    String?  // Optional: store audio file URL if needed
  
  // Timing metadata
  timestamp   DateTime @default(now())
  duration    Int?     // For user messages: speaking duration in ms
  
  // AI analysis (for assistant messages)
  questionType String? // "technical" | "behavioral" | "general"
  feedback    Json?    // Real-time feedback metadata
  
  // Relations
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId, timestamp])
}

model ResumeSession {
  id                String   @id @default(cuid())
  userId            String
  
  // File storage (Supabase Storage)
  resumeFileUrl     String   // Supabase Storage URL
  resumeFileName    String   // Original filename
  resumeFileType    String   // "application/pdf", "text/plain", etc.
  
  // Optional: Keep for backwards compatibility or quick access
  resumeText        String?  // Optional: extracted text if needed
  
  improvedResumeText String?  // AI-improved version
  parsedResumeData   Json?    // Cached parsed resume data (JSON) for fast PDF generation
  
  // OpenAI Assistants API state
  openaiFileId      String?  // OpenAI file ID after upload
  openaiAssistantId String?  // OpenAI assistant ID
  openaiThreadId    String?  // OpenAI thread ID for conversation
  
  // Relations
  messages          ResumeMessage[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([userId, createdAt])
}

model ResumeMessage {
  id          String   @id @default(cuid())
  sessionId   String
  
  role        String   // "user" | "assistant"
  content     String   // Message text
  
  timestamp   DateTime @default(now())
  
  // Relations
  session     ResumeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId, timestamp])
}

enum BotRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum BotSearchFrequency {
  DAILY
  TWICE_DAILY
  WEEKLY
}

model BotConfig {
  id                String             @id @default(cuid())
  userId            String             @unique

  // Search preferences
  keywords          String[]           @default([])  // Job titles / roles to search
  locations         String[]           @default([])  // Target locations
  excludeCompanies  String[]           @default([])  // Company blocklist
  excludeKeywords   String[]           @default([])  // Negative filters in description
  spokenLanguages   String[]           @default([]) // Fluency filters for job language requirements
  remoteOnly        Boolean            @default(false)
  experienceLevel   String?            // "entry" | "mid" | "senior" | "any"
  salaryMin         Int?               // Minimum annual salary (USD)

  // Scheduling
  isActive          Boolean            @default(false)
  searchFrequency   BotSearchFrequency @default(DAILY)
  lastSearchAt      DateTime?

  // Notifications
  telegramChatId    String?            // Telegram chat ID for push notifications

  // Evaluation threshold (0–100); jobs below this are not notified
  minScore          Int                @default(60)

  // Relations
  runs              BotRun[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
  @@index([isActive])
}

model BotResume {
  id             String   @id @default(cuid())
  userId         String

  label          String   // e.g. "Software Engineer", "Product Manager"
  matchKeywords  String[] // Job title keywords that trigger this resume
  isDefault      Boolean  @default(false)

  // File (stored in Supabase Storage)
  fileUrl        String
  fileName       String

  // Parsed content
  rawText        String?  // Full extracted text from PDF
  structuredData Json?    // { name, email, phone, linkedin, github, skills[], experience[], education[], summary }

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model BotRun {
  id              String       @id @default(cuid())
  userId          String
  botConfigId     String

  status          BotRunStatus @default(RUNNING)
  source          String       @default("cron")  // "cron" | "manual"

  // Counts
  jobsFound       Int          @default(0)   // Raw results from search
  jobsNew         Int          @default(0)   // New (not already in DB)
  jobsEvaluated   Int          @default(0)   // Passed through AI evaluator
  jobsApproved    Int          @default(0)   // Score >= minScore

  // Timing
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  duration        Int?         // milliseconds

  // Error details
  errors          Json?
  /** Per-run search metadata (platform stats, etc.) */
  searchMeta      Json?

  // Relations
  botConfig       BotConfig    @relation(fields: [botConfigId], references: [id], onDelete: Cascade)
  botRunLogs      BotRunLog[]
  botRunListings  BotRunListing[]

  @@index([userId, startedAt])
  @@index([botConfigId, startedAt])
}

model BotRunLog {
  id        String   @id @default(cuid())
  botRunId  String
  sequence  Int
  level     String
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  botRun    BotRun   @relation(fields: [botRunId], references: [id], onDelete: Cascade)

  @@index([botRunId, sequence])
}

model BotRunListing {
  id             String   @id @default(cuid())
  botRunId       String
  sequence       Int
  importSource   String
  stage          String
  outcome        String
  title          String
  company        String
  url            String?
  jobSnapshot    Json
  minScoreAtRun  Int
  evaluated      Boolean  @default(false)
  score          Int?
  shouldApply    Boolean?
  flags          String[] @default([])
  reasoning      String?
  resumeMatch    String?
  scoringInputs  Json?
  decisionReason String?
  errorMessage   String?
  createdAt      DateTime @default(now())

  botRun         BotRun   @relation(fields: [botRunId], references: [id], onDelete: Cascade)

  @@unique([botRunId, sequence])
  @@index([botRunId, outcome])
  @@index([botRunId, stage])
}

model ApplicationProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique

  /** Preferred name/email for ATS forms (may differ from Profile.name / auth email) */
  applicationFullName String?
  applicationEmail    String?
  portalSignupPassword String?

  // Contact
  phone               String?
  address             String?
  city                String?
  state               String?
  country             String?

  // Online presence
  linkedinUrl         String?
  githubUrl           String?
  portfolioUrl        String?

  // Work eligibility
  workAuthorization   String?  // "us_citizen" | "green_card" | "h1b" | "ead" | "other"
  requiresSponsorship Boolean  @default(false)

  // Application preferences
  salaryExpectation   Int?     // annual USD
  noticePeriod        String?  // "immediately" | "2_weeks" | "1_month" | "3_months"
  yearsExperience     Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ApplicationAttempt {
  id           String   @id @default(cuid())
  userId       String
  jobId        String

  atsType      String   // "greenhouse" | "lever" | "indeed" | "workday" | "direct"
  status       String   // "filling" | "awaiting_review" | "submitting" | "submitted" | "failed" | "cancelled"

  formData     Json?    // fields that were filled in
  screenshots  String[] @default([])  // Supabase Storage URLs
  errorMessage String?
  submittedAt  DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, jobId])
  @@index([userId, status])
}

enum FeedbackType {
  ERROR
  BUG
  FEATURE_REQUEST
  OTHER
}

enum FeedbackSource {
  WEB
  EXTENSION
}

enum FeedbackStatus {
  NEW
  REVIEWED
  RESOLVED
}

model Feedback {
  id          String         @id @default(cuid())
  userId      String?        // Optional - for authenticated users
  userEmail   String?        // Optional - for extension users or anonymous
  type        FeedbackType
  source      FeedbackSource
  title       String
  description String
  url         String?        // Page/context where issue occurred
  userAgent   String?        // Browser info
  metadata    Json?          // Additional context
  status      FeedbackStatus @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([source])
}

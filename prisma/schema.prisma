generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobSource {
  MANUAL
  LINKEDIN
  INDEED
  COMPANY_SITE
  REFERRAL
  RECRUITER
  EU_REMOTE_JOBS
  WORKABLE
  OTHER
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  GHOSTED
}

enum JobPriority {
  A
  B
  C
}

enum ActivityType {
  NOTE
  STATUS_CHANGE
  EMAIL_UPDATE
  INTERVIEW
  REJECTION
  OFFER
}

model Profile {
  id        String   @id           // Matches Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id          String      @id @default(cuid())
  userId      String

  // Core fields
  title       String
  company     String
  location    String?
  source      JobSource   @default(MANUAL)
  url         String?

  // Status tracking
  status      JobStatus   @default(SAVED)
  priority    JobPriority @default(B)

  // Dates
  savedAt     DateTime    @default(now())
  appliedAt   DateTime?
  interviewAt DateTime?
  nextAction  String?

  // Additional info
  tags        String[]    @default([])
  notes       String?
  salary      String?
  contactName String?
  contactEmail String?

  // Relations
  activities  Activity[]

  // Optional: link to Profile when we start using it
  // (no foreign key yet to avoid breaking existing data)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, status])
  @@index([userId, savedAt])
}

model Activity {
  id          String       @id @default(cuid())
  jobId       String
  userId      String

  type        ActivityType
  fromStatus  JobStatus?
  toStatus    JobStatus?
  description String?

  createdAt   DateTime     @default(now())

  // Relations
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([userId, createdAt])
}

enum EmailProvider {
  IMAP
  GMAIL_OAUTH
  MICROSOFT_OAUTH
}

model EmailIntegration {
  id          String        @id @default(cuid())
  userId      String        @unique

  provider    EmailProvider @default(IMAP)
  email       String

  // IMAP credentials (encrypted)
  imapHost    String?
  imapPort    Int?
  imapUsername String?
  imapPassword String?

  // OAuth tokens (for future Gmail/Microsoft integration)
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?

  // Sync status
  isActive     Boolean      @default(true)
  lastSyncedAt DateTime?
  lastError    String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
}

model ExtensionKey {
  id          String    @id @default(cuid())
  userId      String    @unique  // One active key per user (matches Profile.id / Supabase auth.users.id)
  keyHash     String    @unique  // SHA-256 hash for lookup (never store plain key)
  keyPrefix   String    // "tk_a1b2c3" - visible in UI for identification
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@index([keyHash])
  @@index([userId])
}
